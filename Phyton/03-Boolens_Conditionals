#Exercise_1: Girilen sayı negatifse -1, pozitifse 1, 0 ise 0 çıktısını veren fonk.

def sign(x):
    if x<0:
        x=-1
    elif x>0:
        x=1
    else:
        x=0
    return x   #Not:print(x) yazmıyoruz. Kod çalışsa bile aslında doğru işlemiyor.

